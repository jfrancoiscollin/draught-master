# ── Application ───────────────────────────────────────────────────────────────
# URL publique du service (utilisé pour les liens dans les emails)
APP_URL=https://your-app.up.railway.app

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Clé secrète pour signer les tokens JWT — générer avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Base de données principale (comptes, historique, exercices) ────────────────
# Railway : monter un volume persistant sur /data et définir DB_DIR=/data
# Local   : laisser vide → draught.db créé dans backend/
DB_DIR=/data

# ── Base de données ouvertures (opening book) ─────────────────────────────────
# Railway : même volume que DB_DIR (ou volume séparé)
# Local   : laisser vide → opening_book.db créé dans backend/
OPENING_BOOK_DB=/data/opening_book.db

# ── Moteur Scan ────────────────────────────────────────────────────────────────
# Chemin vers le binaire Scan (copié dans l'image Docker depuis GitHub LFS)
# Ne pas modifier sauf si vous montez le binaire autrement
SCAN_PATH=/usr/local/bin/scan

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Clé API Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (reset de mot de passe) ─────────────────────────────────────────────
# Laisser vide pour désactiver l'envoi d'emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Draught Master <no-reply@example.com>

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=8080

# ── Monitoring (Sentry) ────────────────────────────────────────────────────────
# Laisser vide pour désactiver Sentry
SENTRY_DSN=
